# ──────────────────────────────────────────────────────────────
# Nashrino — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.
# Never commit the real `.env` file.
# ──────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# PostgreSQL via PgBouncer (used by app + worker) — RECOMMENDED for dev + prod
# Requires: docker compose up postgres pgbouncer
DATABASE_URL="postgresql://nashrino:password@localhost:6432/nashrino?schema=public&pgbouncer=true&connection_limit=10"

# Direct PostgreSQL connection (used by Prisma migrate, backup, restore)
DIRECT_DATABASE_URL="postgresql://nashrino:password@localhost:5432/nashrino?schema=public"

# SQLite fallback (quick preview without Docker — dev only, NOT for production):
# DATABASE_URL="file:./db/custom.db"
# Note: when using SQLite, set provider = "sqlite" in prisma/schema.prisma

# Local/production Postgres password used by Docker Compose.
POSTGRES_PASSWORD="change-me"
POSTGRES_PORT="5432"
PGBOUNCER_PORT="6432"

# ── Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# REQUIRED in production — the app throws if missing (see src/lib/auth.ts)
NEXTAUTH_SECRET="change-me-to-a-32-byte-random-string"

# The base URL of the app (no trailing slash)
# Used for OAuth callbacks, email links, etc.
NEXTAUTH_URL="http://localhost:3000"

# ── AI Providers (at least one required for AI caption/hashtag) ──
# Primary: GapGPT (OpenAI-compatible, supports gpt-5-mini)
GAPGPT_API_KEY=""

# Fallback 1: Google Gemini
GEMINI_API_KEY=""

# Fallback 2: z-ai-web-dev-sdk (sandbox default — shared quota)
# No key needed; uses the SDK's default auth.

# ── Realtime (socket.io mini-service) ────────────────────────
# Port the realtime service listens on (must match Caddyfile)
REALTIME_PORT="3003"

# URL the worker uses to POST /emit (job status updates)
# In Docker: http://realtime:3003/emit
REALTIME_EMIT_URL="http://127.0.0.1:3003/emit"

# Shared secret between worker and realtime (Phase 7)
# Generate with: openssl rand -base64 32
EMIT_SECRET="change-me"

# ── Worker (publish-worker mini-service) ──────────────────────
# Port for the worker's health endpoint (Phase 6)
WORKER_HEALTH_PORT="3002"

# ── Redis (required from Phase 6 onward) ──────────────────────
# Used for: BullMQ queues, @upstash/ratelimit, socket.io Redis adapter
# In Docker: redis://redis:6379
REDIS_URL="redis://localhost:6379"

# ── Observability (Phase 2) ───────────────────────────────────
# Sentry DSN for error tracking (optional in dev)
SENTRY_DSN=""

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"

# Enable Prisma query logging (noisy — set to 0 in production)
LOG_QUERIES="0"

# ── Media Storage (Phase 9 — S3-compatible) ───────────────────
# Leave empty to use local disk (public/uploads/) in dev
S3_ENDPOINT=""
S3_BUCKET="nashrino-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="us-east-1"

# CDN base URL for serving media (Phase 9)
# Example: https://cdn.nashrino.example.com
CDN_BASE_URL=""

# ── Rate Limiting (Phase 8 — Upstash Redis) ───────────────────
# Optional: use Upstash Redis REST API instead of self-hosted Redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Demo / Seed (dev only) ────────────────────────────────────
# Demo credentials are created by `bun run seed:auth`
# Demo user: demo@nashrino.ir / demo1234
# These are NEVER created in production (seed script checks NODE_ENV)

# ── BullMQ Worker (Sprint B) ───────────────────────────────────
# Password for Bull Board dashboard at worker:3002/board
BOARD_PASSWORD="nashrino"

# Worker concurrency (how many jobs to process simultaneously)
WORKER_CONCURRENCY="5"
