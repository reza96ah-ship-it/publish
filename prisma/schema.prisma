  @@index([workspaceId, metricType])
}

/* ─── Per-post metric snapshots (Issue #215) ─── */

// Daily metric values for one Publication, collected from the provider where
// its API exposes per-post insights (see POST_METRICS_SUPPORT). Providers that
// don't expose per-post metrics simply have no rows — the UI shows an honest
// "not available" state.
model PostMetricSnapshot {
  id            String   @id @default(cuid())
  workspaceId   String
  publicationId String
  date          String   // YYYY-MM-DD
  metricType    String   // reach, impressions, likes, comments, saved, views
  value         Int
  createdAt     DateTime @default(now())

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  publication Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@unique([publicationId, date, metricType])
  @@index([workspaceId, date])
  @@index([publicationId])
}

/* ─── Notifications ─── */

model Notification {
  id          String   @id @default(cuid())
  workspaceId String
  type        String   // publish_success, publish_failed, approval_requested, inbox_new, token_expiring, channel_disconnected
  title       String
  body        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

