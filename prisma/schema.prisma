  value String
  type  String @default("string")
}

/* ─── Draft Persistence (MISS-04) ─── */

// One draft row per user per workspace — upserted on every autosave tick.
model ContentDraft {
  id          String   @id @default(cuid())
  workspaceId String
  authorId    String
  content     Json     // { title, caption, hashtags, note, campaignId, mediaIds, scheduleMode }
  channelIds  String[] // platform UUIDs selected in the compose view
  scheduledAt String?  // ISO string, null when scheduleMode != 'schedule'
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, authorId])
  @@index([workspaceId])
}

/* ─── Transactional Outbox (MISS-01) ─── */

// Written in the same DB transaction as Content + PublishJob.
// Dispatcher in publish-worker polls this table and enqueues to BullMQ.
// Uses FOR UPDATE SKIP LOCKED to prevent double-claiming by concurrent dispatchers.
model OutboxEvent {
  id            String    @id @default(cuid())
  workspaceId   String
  aggregateType String    @default("content")
  aggregateId   String    // contentId
  eventType     String    @default("publish_requested")
  payload       Json      // { jobId, contentId, platformId, workspaceId, scheduledAt, idempotencyKey, publicationId, revisionId }
  traceParent   String?
  // Issue #148: explicit state machine — pending, claimed, delivered, retry_wait, dead_letter, cancelled
  status        String    @default("pending")
  attemptCount  Int       @default(0)
  availableAt   DateTime  @default(now())
  // Issue #148: lease/fencing fields
  lockedAt      DateTime?
  lockedBy      String?   // dispatcher instance ID
  lockExpiresAt DateTime? // when the lease expires (for crash recovery)
  deliveredAt   DateTime?
  // Issue #148: error classification
  lastError     String?
  lastErrorCategory String? // redis, db, serialization, payload, config
  lastSafeError String?     // safe user message (no secrets)
  // Issue #148: dead-letter + replay
  deadLetteredAt DateTime?
  replayedFromId String?    // original event ID if this is a replay
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, availableAt])
  @@index([aggregateId])
  // Issue #148: index for lease expiry recovery queries
  @@index([status, lockExpiresAt])
}

/* ─── Inbox Saved Replies ─── */

model SavedReply {
  id          String   @id @default(cuid())
  workspaceId String
