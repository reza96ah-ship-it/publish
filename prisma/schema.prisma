generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/* ─── Auth & Identity ─── */

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  failedAttempts Int     @default(0)
  lockedUntil   DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Issue #121: MFA (TOTP) for administrator accounts.
  // mfaSecretPending: encrypted secret awaiting verification (setup flow)
  // mfaSecret:        encrypted active secret (null = MFA not enabled)
  // mfaBackupCodes:   JSON array of hashed backup codes for account recovery
  // mfaEnabledAt:     when MFA was activated (null = not enabled)
  mfaSecretPending String?
  mfaSecret        String?
  mfaBackupCodes   String?
  mfaEnabledAt     DateTime?

  memberships   WorkspaceMember[]
  auditLogs     AuditLog[]
  accounts      Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String
  type       String   @default("email")
  expires    DateTime
  createdAt  DateTime @default(now())

  @@index([identifier, expires])
  @@index([token])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  workspaceId String?
  action      String
  resource    String   @default("")
  metadata    Json?
  ipHash      String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}

/* ─── Workspace & Team ─── */

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  category  String   @default("")
  phone     String   @default("")
  description String @default("")
  timezone  String   @default("Asia/Tehran")
  plan      String   @default("free")
  brandPrimaryColor String @default("#0F766E")
  brandAccentColor  String @default("#2563EB")
  brandVoice        String @default("")
  defaultCta        String @default("")
  contentGuidelines String @default("")
  defaultHashtags   String @default("")
  captionFooter     String @default("")
  persianDigits     Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       WorkspaceMember[]
  platforms     Platform[]
  campaigns     Campaign[]
  contents      Content[]
  media         Media[]
  publishJobs   PublishJob[]
  inboxMessages InboxMessage[]
  analytics     AnalyticsSnapshot[]
  notifications Notification[]
  drafts        ContentDraft[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  name        String   @default("کاربر")
  email       String   @default("")
  role        String   @default("member") // admin, editor, approver, viewer
  avatarUrl   String?
  createdAt   DateTime @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assigneeJobs  PublishJob[]
  assignedMessages InboxMessage[]

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

/* ─── Platform Connections ─── */

model Platform {
  id          String   @id @default(cuid())
  workspaceId String
  type        String   // instagram, telegram, linkedin, rubika, eitaa, bale
  name        String
  username    String   @default("")
  avatarUrl   String?
  accountKind String   @default("professional") // professional, personal (ig); channel, group (tg)
  status      String   @default("active") // active, expired, error, disconnected
  lastSuccessAt DateTime?
  lastError   String?
  circuitState String  @default("closed") // closed, open, half_open
  primaryIssue String?
  /** Bot token (Telegram/Bale/Rubika) or OAuth access token (Instagram/LinkedIn).
      NOTE: In production, encrypt at rest with AUTH_SECRET. */
  tokenSecret String?
  /** Platform-specific target: chat_id (TG/Bale/Rubika), ig-user-id (IG), author URN (LinkedIn) */
  targetId    String?
  // Issue #116: Instagram token expiry lifecycle — 60-day long-lived tokens
  // expire silently. Storing the expiry lets the worker warn users in advance
  // and surface auth errors instead of retrying dead tokens.
  tokenExpiresAt  DateTime?
  tokenScopes     String?
  lastValidatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentLinks  ContentPlatform[]
  publishJobs   PublishJob[]
  inboxMessages InboxMessage[]

  @@index([workspaceId])
  @@index([workspaceId, type])
  @@index([workspaceId, status])
  @@index([status])
}

/* ─── Campaigns ─── */

model Campaign {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  status      String   @default("active") // active, paused, completed, archived
  startDate   DateTime?
  endDate     DateTime?
  goalType    String?
  goalValue   Int      @default(0)
  healthLabel String   @default("در مسیر برنامه")
  healthColor String   @default("text-emerald-700 bg-emerald-50 border-emerald-200")
  ownerName   String?
  topBlocker  String?
  pubProgress Int      @default(0)
  goalCompletion String @default("")
  daysRemaining  String @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contents  Content[]
  jobs      PublishJob[]

  @@index([workspaceId])
  @@index([workspaceId, status])
}

/* ─── Content ─── */

model Content {
  id          String   @id @default(cuid())
  workspaceId String
  campaignId  String?
  title       String
  body        String?
  hashtags    String?
  internalNote String?
  status      String   @default("draft") // draft, review, approved, scheduled, published, failed, rejected
  thumbnailUrl String?
  authorName  String?
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Approval workflow fields
  approvedById  String?
  approvedAt    DateTime?
  rejectedReason String?
  reviewDeadline DateTime?

  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign    Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  platforms   ContentPlatform[]
  jobs        PublishJob[]
  comments    ContentComment[]
  versions    ContentVersion[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, scheduledAt])
  @@index([campaignId])
  @@index([scheduledAt])
  @@index([status])
}

model ContentComment {
  id            String   @id @default(cuid())
  contentId     String
  userId        String
  userName      String   @default("کاربر")
  body          String
  selectionStart Int?
  selectionEnd   Int?
  resolved      Boolean  @default(false)
  parentId      String?
  createdAt     DateTime @default(now())

  content   Content         @relation(fields: [contentId], references: [id], onDelete: Cascade)
  parent    ContentComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   ContentComment[] @relation("CommentReplies")

  @@index([contentId, resolved])
  @@index([parentId])
}

model ContentVersion {
  id          String   @id @default(cuid())
  contentId   String
  body        String
  editedBy    String   @default("system")
  editSummary String?
  createdAt   DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId, createdAt])
}

model ContentPlatform {
  id        String   @id @default(cuid())
  contentId String
  platformId String

  content  Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([contentId, platformId])
  @@index([contentId])
  @@index([platformId])
}

/* ─── Publishing Queue ─── */

model PublishJob {
  id          String   @id @default(cuid())
  workspaceId String
  contentId   String
  platformId  String
  campaignId  String?
  assigneeId  String?
  status      String   @default("pending") // pending, processing, live, success, failed, action, scheduled, cancelled
  progress    Int      @default(0)
  processLabel String  @default("در انتظار")
  idempotencyKey String @default("")
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  retryCount  Int      @default(0)
  externalId  String?
  thumbnailUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace  Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content    Content               @relation(fields: [contentId], references: [id], onDelete: Cascade)
  platform   Platform              @relation(fields: [platformId], references: [id])
  campaign   Campaign?             @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  assignee   WorkspaceMember?      @relation(fields: [assigneeId], references: [id])
  attempts   PublicationAttempt[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([status, scheduledAt])
  @@index([platformId])
  @@index([assigneeId])
  @@unique([idempotencyKey])
}

/* ─── Publication Attempt Ledger (MISS-02) ─── */

// One row per provider call attempt. Prevents duplicate posts when
// a worker crash occurs after provider success but before DB update.
model PublicationAttempt {
  id                     String    @id @default(cuid())
  publishJobId           String
  attemptNumber          Int
  requestFingerprint     String    // sha256(platformId + ':' + contentId + ':' + attemptNumber)
  providerOperationId    String?
  providerPostId         String?   // externalId from provider (set on provider_success)
  outcome                String    // started|provider_success|local_success|retryable_failure|permanent_failure|outcome_unknown
  errorCategory          String?
  safeUserMessage        String?
  startedAt              DateTime
  providerAcknowledgedAt DateTime?
  locallyCommittedAt     DateTime?
  completedAt            DateTime?

  job PublishJob @relation(fields: [publishJobId], references: [id], onDelete: Cascade)

  @@index([publishJobId])
  @@index([requestFingerprint])
}

/* ─── Media Library ─── */

model Media {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  fileType    String   // image/jpeg, video/mp4, etc.
  fileSize    Int      @default(0)
  url         String
  thumbnailUrl String?
  folder      String   @default("عمومی")
  width       Int?
  height      Int?
  tags        String   @default("")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, folder])
}

/* ─── Inbox ─── */

model InboxMessage {
  id          String   @id @default(cuid())
  workspaceId String
  platformId  String
  senderName  String
  senderAvatar String?
  message     String
  isRead      Boolean  @default(false)
  isReplied   Boolean  @default(false)
  reply       String?
  platformType String
  externalId  String?
  messageType String   @default("comment") // comment, dm, mention
  assigneeId  String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform  Platform  @relation(fields: [platformId], references: [id])
  assignee  WorkspaceMember? @relation(fields: [assigneeId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, isRead])
  @@index([platformId])
  @@index([assigneeId])
}

/* ─── Analytics Snapshots ─── */

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  workspaceId String
  date        String   // YYYY-MM-DD
  platform    String?
  metricType  String   // reach, impressions, engagement, followers, clicks, conversions
  value       Int
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, date, platform, metricType])
  @@index([workspaceId, date])
  @@index([workspaceId, metricType])
}

/* ─── Notifications ─── */

model Notification {
  id          String   @id @default(cuid())
  workspaceId String
  type        String   // publish_success, publish_failed, approval_requested, inbox_new, token_expiring, channel_disconnected
  title       String
  body        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isRead])
  @@index([workspaceId, createdAt])
}

/* ─── Settings ─── */

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("string")
}

/* ─── Draft Persistence (MISS-04) ─── */

// One draft row per user per workspace — upserted on every autosave tick.
model ContentDraft {
  id          String   @id @default(cuid())
  workspaceId String
  authorId    String
  content     Json     // { title, caption, hashtags, note, campaignId, mediaIds, scheduleMode }
  channelIds  String[] // platform UUIDs selected in the compose view
  scheduledAt String?  // ISO string, null when scheduleMode != 'schedule'
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, authorId])
  @@index([workspaceId])
}

/* ─── Transactional Outbox (MISS-01) ─── */

// Written in the same DB transaction as Content + PublishJob.
// Dispatcher in publish-worker polls this table and enqueues to BullMQ.
// Uses FOR UPDATE SKIP LOCKED to prevent double-claiming by concurrent dispatchers.
model OutboxEvent {
  id            String    @id @default(cuid())
  workspaceId   String
  aggregateType String    @default("content")
  aggregateId   String    // contentId
  eventType     String    @default("publish_requested")
  payload       Json      // { jobId, contentId, platformId, workspaceId, scheduledAt, idempotencyKey }
  traceParent   String?
  status        String    @default("pending") // pending, delivered, failed
  attemptCount  Int       @default(0)
  availableAt   DateTime  @default(now())
  lockedAt      DateTime?
  lockedBy      String?   // dispatcher instance ID for fencing
  deliveredAt   DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, availableAt])
  @@index([aggregateId])
}
