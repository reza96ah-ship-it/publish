/* ─── #255: Public API tokens + signed webhooks ─── */

model ApiToken {
  id           String    @id @default(cuid())
  workspaceId  String
  name         String                    // human label (e.g. "Zapier integration")
  tokenHash    String    @unique         // SHA-256 hash of plaintext (never store plaintext)
  prefix       String                    // first 8 chars of plaintext for UI display "nsh_abc1…"
  scopes       String[]  @default([])    // content:read, content:write, publications:read, inbox:read, reports:read
  lastUsedAt   DateTime?
  expiresAt    DateTime?                 // null = no expiry
  revokedAt    DateTime?
  createdById  String                    // user who created it
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Webhook {
  id              String   @id @default(cuid())
  workspaceId     String
  url             String                    // HTTPS endpoint
  events          String[]                  // publish.success, publish.failed, inbox.new, etc.
  secretEncrypted String                    // HMAC signing secret, encrypted via src/lib/crypto.ts
  isActive        Boolean  @default(true)
  lastTriggeredAt DateTime?
  lastResponseStatus Int?
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace  Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([workspaceId])
  @@index([isActive])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  workspaceId     String
  webhookId       String
  eventId         String                    // idempotency: stable per (webhookId, eventType, aggregateId)
  eventType       String                    // publish.success, publish.failed, inbox.new, ...
  payload         Json
  status          String   @default("pending")  // pending, claimed, delivered, retry_wait, dead_letter, cancelled
  attemptCount    Int      @default(0)
  availableAt     DateTime @default(now())
  lockedAt        DateTime?
  lockedBy        String?
  lockExpiresAt   DateTime?
  deliveredAt     DateTime?
  responseStatus  Int?
  lastError       String?
  lastErrorCategory String?
  deadLetteredAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@index([webhookId, eventType])
  @@index([status, lockExpiresAt])
}

/* ─── #248: Customer profiles + case management ─── */

model Customer {
  id          String   @id @default(cuid())
  workspaceId String
  name        String   @default("")
  email       String?
  phone       String?
  // Social handles: { "instagram": "@user", "telegram": "@user" }
  socialHandles Json?
  avatarUrl   String?
  tags        String[] @default([])
  notes       String?  // Internal notes (agent-visible only)
  consentStatus String @default("unknown") // unknown, granted, denied
  optOutAt    DateTime?
  // For merge/dedup: if merged, points to the canonical customer
  mergedIntoId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mergedInto  Customer? @relation("CustomerMerges", fields: [mergedIntoId], references: [id])
  mergedFrom  Customer[] @relation("CustomerMerges")
  interactions CustomerInteraction[]
  cases       CaseParticipant[]

  @@index([workspaceId])
  @@index([workspaceId, email])
  @@index([mergedIntoId])
}

model CustomerInteraction {
  id          String   @id @default(cuid())
  customerId  String
  workspaceId String
  // Type: comment, dm, mention, reply
  type        String
  // Platform: instagram, telegram, etc.
  platform    String
  // The message content (truncated if long)
  content     String
  // Direction: inbound (from customer) or outbound (from agent)
  direction   String   @default("inbound")
  // Link to the original InboxMessage if applicable
  inboxMessageId String?
  // Agent who handled it (if outbound)
  handledBy   String?
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([workspaceId])
}

model Case {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  description String?
  status      String   @default("open") // open, in_progress, resolved, closed
  priority    String   @default("normal") // low, normal, high, urgent
  // Outcome notes filled when resolved/closed
  resolution  String?
  assigneeId  String?  // WorkspaceMember ID
  // Linked inbox messages
  linkedMessageIds String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?
  closedAt    DateTime?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  participants CaseParticipant[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([assigneeId])
}

model CaseParticipant {
  id          String   @id @default(cuid())
  caseId      String
  customerId  String
  role        String   @default("primary") // primary, cc, mentioned
  addedAt     DateTime @default(now())

  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([caseId, customerId])
  @@index([caseId])
  @@index([customerId])
}

/* ─── #249: Versioned workflow builder + run history ─── */

model Automation {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  // Current version number (increments on each save)
  version     Int      @default(1)
  // The full automation definition as JSON:
  // { triggers: [...], conditions: [...], actions: [...] }
  // Each trigger: { type: 'schedule'|'keyword'|'status_change'|'provider_event'|'date_holiday', config: {...} }
  // Each condition: { type: 'channel'|'tag'|'campaign'|'time_window'|'approval_state', config: {...} }
  // Each action: { type: 'create_draft'|'add_to_queue'|'send_notification'|'assign_inbox'|'add_reply'|'add_tag'|'call_webhook', config: {...} }
  definition Json
  // Previous version's definition (for rollback)
  previousDefinition Json?
  isActive    Boolean  @default(false)
  isPaused    Boolean  @default(false)
  // Dry run mode: log what would happen but don't execute actions
  dryRunMode  Boolean  @default(false)
  // Kill switch: when true, all runs are immediately cancelled
  killSwitch  Boolean  @default(false)
  // Rate limiting: max runs per hour
  maxRunsPerHour Int   @default(10)
  // Require human approval for AI-generated actions
  requireApproval Boolean @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs      AutomationRun[]

  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@index([killSwitch])
}

model AutomationRun {
  id            String   @id @default(cuid())
  automationId  String
  workspaceId   String
  // The version of the automation definition that was used
  version       Int
  // Trigger that fired: { type, config, matchedData }
  trigger       Json
  // Conditions evaluated: [{ type, passed, details }]
  conditions    Json
  // Actions executed: [{ type, status, result, error, timestamp }]
  actions       Json
  status        String   @default("pending") // pending, running, completed, failed, cancelled, approval_required
  // If approval_required, who needs to approve
  approverId    String?
  approvedAt    DateTime?
  // Error details if failed
  error         String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([automationId, createdAt])
  @@index([workspaceId])
  @@index([status])
}

/* ─── #251: Social listening + spike alerts ─── */

model ListeningQuery {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  // The search terms to track (brand names, competitor names, hashtags, etc.)
  keywords    String[]
  // Language filter: 'fa', 'en', 'ar', or empty for all
  languages   String[] @default([])
  // Noise filters
  minEngagement Int    @default(0)  // minimum engagement to show
  excludeSpam  Boolean @default(true)
  // Spike alert config
  spikeAlertEnabled Boolean @default(true)
  spikeThreshold Float @default(3.0) // standard deviations above mean
  spikeWindowHours Int  @default(24) // rolling window for baseline
  // Which providers to monitor
  providers   String[] @default(["instagram"]) // instagram, telegram, etc.
  // Coverage disclosure (what is NOT covered)
  coverageNotes String? // e.g. "Instagram comments only — DMs not accessible via API"
  // Saved search share token
  shareToken  String?  @unique
  isActive    Boolean  @default(true)
  lastCheckedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mentions  ListeningMention[]

  @@index([workspaceId])
  @@index([isActive])
}

model ListeningMention {
  id          String   @id @default(cuid())
  queryId     String
  workspaceId String
  // Source
  provider    String   // instagram, telegram, etc.
  // The mention content
  content     String
  authorName  String
  authorAvatar String?
  // URL to the original post/comment (if available)
  sourceUrl   String?
  // Engagement metrics at time of capture
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  // Language detection result
  detectedLanguage String? // fa, en, ar
  // Spam signal (0-1, higher = more likely spam)
  spamScore   Float    @default(0)
  // Human-verified sentiment (null = not yet verified)
  verifiedSentiment String? // positive, neutral, negative
  // Auto-detected sentiment (NEVER shown without human verification — #251 requirement)
  autoSentiment String?
  // Is this mention part of a spike?
  isSpike     Boolean  @default(false)
  spikeScore  Float?   // how many std devs above mean
  // Coverage disclosure
  coverageSource String? // e.g. "Instagram Graph API — comments only"
  mentionedAt DateTime // when the mention was posted (provider timestamp)
  createdAt   DateTime @default(now()) // when we captured it

  query     ListeningQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([queryId, mentionedAt])
  @@index([workspaceId])
  @@index([isSpike])
}

/* ─── #254: Agency multi-client overview ─── */

model AgencyProfile {
