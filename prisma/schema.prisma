generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

/* ─── Auth & Identity ─── */

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  failedAttempts Int     @default(0)
  lockedUntil   DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Issue #121: MFA (TOTP) for administrator accounts.
  // mfaSecretPending: encrypted secret awaiting verification (setup flow)
  // mfaSecret:        encrypted active secret (null = MFA not enabled)
  // mfaBackupCodes:   JSON array of hashed backup codes for account recovery
  // mfaEnabledAt:     when MFA was activated (null = not enabled)
  mfaSecretPending String?
  mfaSecret        String?
  mfaBackupCodes   String?
  mfaEnabledAt     DateTime?

  memberships   WorkspaceMember[]
  auditLogs     AuditLog[]
  accounts      Account[]
  invitationsSent WorkspaceInvitation[] @relation("InvitedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String
  type       String   @default("email")
  expires    DateTime
  createdAt  DateTime @default(now())

  @@index([identifier, expires])
  @@index([token])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  workspaceId String?
  action      String
  resource    String   @default("")
  metadata    Json?
  ipHash      String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}

/* ─── Workspace & Team ─── */

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  category  String   @default("")
  phone     String   @default("")
  description String @default("")
  timezone  String   @default("Asia/Tehran")
  plan      String   @default("free")
  brandPrimaryColor String @default("#0F766E")
  brandAccentColor  String @default("#2563EB")
  brandVoice        String @default("")
  defaultCta        String @default("")
  contentGuidelines String @default("")
  defaultHashtags   String @default("")
  captionFooter     String @default("")
  persianDigits     Boolean @default(true)
  workWeek          String  @default("sat-wed")
  onboardingStep    Int     @default(0)
  onboardingCompleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       WorkspaceMember[]
  platforms     Platform[]
  campaigns     Campaign[]
  contents      Content[]
  media         Media[]
  publishJobs   PublishJob[]
  inboxMessages InboxMessage[]
  analytics     AnalyticsSnapshot[]
  notifications Notification[]
  drafts        ContentDraft[]
  invitations   WorkspaceInvitation[]
  publications  Publication[]
  revisions    ContentRevision[]
  featureFlags  FeatureFlag[]
  utmPresets    UtmPreset[]
  savedReplies   SavedReply[]
  autoTagRules   AutoTagRule[]
  commentDmRules CommentDmRule[]
  commentDmLogs  CommentDmLog[]
  postingSchedules PostingSchedule[]
  engagementHeatmaps EngagementHeatmap[]
}

model FeatureFlag {
  id          String   @id @default(cuid())
  workspaceId String
  flag        String
  enabled     Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, flag])
}

/* ─── UTM Presets (Issue #246) ─── */
model UtmPreset {
  id          String   @id @default(cuid())
  workspaceId String
  name        String                    // Display name, e.g. "Instagram Organic"
  source      String                    // utm_source
  medium      String                    // utm_medium
  campaign    String   @default("")     // utm_campaign (template, may include {title})
  term        String   @default("")     // utm_term (optional)
  content     String   @default("")     // utm_content (optional)
  platforms   String[] @default([])     // platform ids this preset applies to
  isDefault   Boolean  @default(false)  // auto-apply to new posts
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  name        String   @default("کاربر")
  email       String   @default("")
  role        String   @default("member") // admin, editor, approver, viewer
  avatarUrl   String?
  createdAt   DateTime @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assigneeJobs  PublishJob[]
  assignedMessages InboxMessage[]

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

/* ─── Workspace Invitations (Issue #143) ─── */

// Replaces the fake userId pattern. Invitations store a hashed token and
// create a real WorkspaceMember only when the invited user accepts.
model WorkspaceInvitation {
  id              String   @id @default(cuid())
  workspaceId     String
  emailNormalized String   // lowercase + trimmed email for matching
  role            String   @default("viewer") // admin, editor, approver, viewer
  tokenHash       String   @unique // SHA-256 hash of the plaintext token (never store plaintext)
  invitedById     String
  expiresAt       DateTime // 7-day expiry (documented policy)
  acceptedAt      DateTime?
  acceptedById    String?  // the User who accepted (null until accepted)
  revokedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Restrict)

  @@unique([workspaceId, emailNormalized]) // one active invitation per email per workspace
  @@index([emailNormalized, expiresAt])
  @@index([workspaceId, createdAt])
}

/* ─── Platform Connections ─── */

model Platform {
  id          String   @id @default(cuid())
  workspaceId String
  type        String   // instagram, telegram, linkedin, rubika, eitaa, bale
  name        String
  username    String   @default("")
  avatarUrl   String?
  accountKind String   @default("professional") // professional, personal (ig); channel, group (tg)
  status      String   @default("active") // active, expired, error, disconnected
  lastSuccessAt DateTime?
  lastError   String?
  circuitState String  @default("closed") // closed, open, half_open
  primaryIssue String?
  /** Bot token (Telegram/Bale/Rubika) or OAuth access token (Instagram/LinkedIn).
      NOTE: In production, encrypt at rest with AUTH_SECRET. */
  tokenSecret String?
  /** Platform-specific target: chat_id (TG/Bale/Rubika), ig-user-id (IG), author URN (LinkedIn) */
  targetId    String?
  // Issue #116: Instagram token expiry lifecycle — 60-day long-lived tokens
  // expire silently. Storing the expiry lets the worker warn users in advance
  // and surface auth errors instead of retrying dead tokens.
  tokenExpiresAt  DateTime?
  tokenScopes     String?
  lastValidatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentLinks   ContentPlatform[]
  publishJobs    PublishJob[]
  inboxMessages  InboxMessage[]
  commentDmRules CommentDmRule[]
  postingSchedules PostingSchedule[]

  @@index([workspaceId])
  @@index([workspaceId, type])
  @@index([workspaceId, status])
  @@index([status])
  @@index([tokenExpiresAt])
}

/* ─── Campaigns ─── */

model Campaign {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  status      String   @default("active") // active, paused, completed, archived
  startDate   DateTime?
  endDate     DateTime?
  goalType    String?
  goalValue   Int      @default(0)
  healthLabel String   @default("در مسیر برنامه")
  healthColor String   @default("text-emerald-700 bg-emerald-50 border-emerald-200")
  ownerName   String?
  topBlocker  String?
  pubProgress Int      @default(0)
  goalCompletion String @default("")
  daysRemaining  String @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contents  Content[]
  jobs      PublishJob[]

  @@index([workspaceId])
  @@index([workspaceId, status])
}

/* ─── Content ─── */

model Content {
  id          String   @id @default(cuid())
  workspaceId String
  campaignId  String?
  title       String
  body        String?
  hashtags    String?
  internalNote String?
  status      String   @default("draft") // draft, review, approved, scheduled, published, failed, rejected
  thumbnailUrl String?
  authorName  String?
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Approval workflow fields
  approvedById  String?
  approvedAt    DateTime?
  rejectedReason String?
  reviewDeadline DateTime?

  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign    Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  platforms   ContentPlatform[]
  jobs        PublishJob[]
  comments    ContentComment[]
  versions    ContentVersion[]
  revisions  ContentRevision[]
  publications Publication[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, scheduledAt])
  @@index([campaignId])
  @@index([scheduledAt])
  @@index([status])
}

/* ─── Content Revisions (Issue #145: immutable version of content) ─── */

// An immutable snapshot of the content at the time of publish/review submission.
// The worker reads this — never the mutable Content row — so later edits don't
// affect already-queued publications.
model ContentRevision {
  id          String   @id @default(cuid())
  contentId   String
  workspaceId String
  title       String
  body        String?
  hashtags    String?
  internalNote String?
  authorName  String?
  version     Int      @default(1)
  createdAt   DateTime @default(now())

  content    Content          @relation(fields: [contentId], references: [id], onDelete: Cascade)
  workspace  Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  media      RevisionMedia[]
  variants   ChannelVariant[]
  publications Publication[]

  @@index([contentId])
  @@index([workspaceId])
}

/* ─── Channel Variants (Issue #145: per-channel caption overrides) ─── */

// Destination-specific caption/body for one connected channel.
// Keyed by revision + platform ID so each destination gets its own text.
model ChannelVariant {
  id          String   @id @default(cuid())
  revisionId  String
  platformId  String
  caption     String?
  // The effective caption the adapter receives (override or default from revision body)

  revision   ContentRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@unique([revisionId, platformId])
  @@index([platformId])
}

/* ─── Revision Media (Issue #145: ordered media relations) ─── */

// Ordered relation between a revision and media assets.
// Replaces the old pattern of manufacturing a single photo from Content.thumbnailUrl.
model RevisionMedia {
  id          String   @id @default(cuid())
  revisionId  String
  mediaId     String   // references Media.id (validated asset)
  position    Int      // 0-based ordering (first item = position 0)
  role        String   @default("photo") // photo, video, reel, document
  altText     String?

  revision   ContentRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@unique([revisionId, position])
  @@index([revisionId])
  @@index([mediaId])
}

/* ─── Publication (Issue #145: first-class delivery record per destination) ─── */

// One destination-specific delivery record with provider state and receipt.
// Replaces the overloaded use of PublishJob as both intent and result.
model Publication {
  id                  String   @id @default(cuid())
  workspaceId         String
  contentId           String
  revisionId          String
  platformId          String
  publishJobId        String?  // links to the legacy PublishJob for compatibility
  campaignId          String?

  // Publication state (typed enum)
  status              String   @default("pending") // pending, processing, success, failed, action, scheduled, cancelled
  processLabel        String   @default("در انتظار")
  progress            Int      @default(0)

  // Scheduling
  scheduledAt         DateTime?

  // Provider receipt
  providerPostId      String?
  providerAcknowledgedAt DateTime?

  // Idempotency + reconciliation
  requestFingerprint  String?  // sha256(platformId + contentId + revisionId)
  providerOperationId String?
  // Issue #149: stable logical operation identity — one per Publication, never changes across retries
  publicationOperationId String? @unique // stable idempotency key for provider calls
  reconciliationStatus String? // null, confirmed_success, confirmed_failure, still_unknown

  // Error data (safe, no secrets)
  errorCategory       String?  // auth, rate_limit, network, not_found, unknown
  errorMessage        String?  // safe Persian message

  // Timestamps
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content     Content     @relation(fields: [contentId], references: [id], onDelete: Cascade)
  revision    ContentRevision @relation(fields: [revisionId], references: [id], onDelete: Restrict)
  attempts    PublicationAttempt[]
  commentDmRules CommentDmRule[]

  @@unique([revisionId, platformId])
  @@index([workspaceId])
  @@index([contentId])
  @@index([revisionId])
  @@index([platformId])
  @@index([status])
  @@index([requestFingerprint])
}

model ContentComment {
  id            String   @id @default(cuid())
  contentId     String
  userId        String
  userName      String   @default("کاربر")
  body          String
  selectionStart Int?
  selectionEnd   Int?
  resolved      Boolean  @default(false)
  parentId      String?
  createdAt     DateTime @default(now())

  content   Content         @relation(fields: [contentId], references: [id], onDelete: Cascade)
  parent    ContentComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   ContentComment[] @relation("CommentReplies")

  @@index([contentId, resolved])
  @@index([parentId])
}

model ContentVersion {
  id          String   @id @default(cuid())
  contentId   String
  body        String
  editedBy    String   @default("system")
  editSummary String?
  createdAt   DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId, createdAt])
}

model ContentPlatform {
  id        String   @id @default(cuid())
  contentId String
  platformId String

  content  Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([contentId, platformId])
  @@index([contentId])
  @@index([platformId])
}

/* ─── Publishing Queue ─── */

model PublishJob {
  id          String   @id @default(cuid())
  workspaceId String
  contentId   String
  platformId  String
  campaignId  String?
  assigneeId  String?
  status      String   @default("pending") // pending, processing, live, success, failed, action, scheduled, cancelled
  progress    Int      @default(0)
  processLabel String  @default("در انتظار")
  idempotencyKey String @default("")
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  retryCount  Int      @default(0)
  externalId  String?
  thumbnailUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace  Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content    Content               @relation(fields: [contentId], references: [id], onDelete: Cascade)
  platform   Platform              @relation(fields: [platformId], references: [id])
  campaign   Campaign?             @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  assignee   WorkspaceMember?      @relation(fields: [assigneeId], references: [id])
  attempts   PublicationAttempt[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([status, scheduledAt])
  @@index([platformId])
  @@index([assigneeId])
  @@unique([idempotencyKey])
}

/* ─── Publication Attempt Ledger (MISS-02) ─── */

// One row per provider call attempt. Prevents duplicate posts when
// a worker crash occurs after provider success but before DB update.
model PublicationAttempt {
  id                     String    @id @default(cuid())
  publishJobId           String
  publicationId          String?   // Issue #145: links to the new Publication entity
  attemptNumber          Int
  requestFingerprint     String    // sha256(platformId + ':' + contentId + ':' + attemptNumber)
  providerOperationId    String?
  providerPostId         String?   // externalId from provider (set on provider_success)
  outcome                String    // started|provider_success|local_success|retryable_failure|permanent_failure|outcome_unknown
  errorCategory          String?
  safeUserMessage        String?
  startedAt              DateTime
  providerAcknowledgedAt DateTime?
  locallyCommittedAt     DateTime?
  completedAt            DateTime?

  job PublishJob @relation(fields: [publishJobId], references: [id], onDelete: Cascade)
  publication Publication? @relation(fields: [publicationId], references: [id], onDelete: SetNull)

  @@index([publishJobId])
  @@index([publicationId])
  @@index([requestFingerprint])
}

/* ─── Media Library ─── */

// Issue #146: lifecycle-tracked media asset. A row is created at presign time as
// "pending" and only becomes visible/usable (status="validated") after the
// uploaded object has been fetched back from storage and its real content
// (magic bytes, checksum, size, dimensions) has been verified server-side.
model Media {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  fileType    String   // declared content-type at presign time (image/jpeg, video/mp4, ...)
  fileSize    Int      @default(0) // declared size at presign time, bytes
  url         String   @default("") // public delivery URL — only meaningful once status="validated"
  thumbnailUrl String?
  folder      String   @default("عمومی")
  width       Int?
  height      Int?
  tags        String   @default("")
  createdAt   DateTime @default(now())

  // Lifecycle state machine: pending -> uploaded -> validating -> validated | rejected
  // (also: deleting -> deleted)
  status        String    @default("pending")
  uploaderId    String?
  storageProvider String  @default("local") // local | s3
  storageBucket String?
  storageKey    String    @default("")
  declaredType  String?   // content-type declared by the client at presign time
  detectedType  String?   // real type detected from magic bytes during confirm
  actualSize    Int?      // bytes actually written to storage (set after upload)
  checksumAlgo  String?
  checksumValue String?
  durationMs    Int?      // video duration, when detectable
  codec         String?   // video codec, when detectable
  expiresAt     DateTime? // pending-upload deadline; cleanup removes rows past this with status != validated
  validatedAt   DateTime?
  rejectedReason String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, folder])
  @@index([workspaceId, status])
  @@index([status, expiresAt])
}

/* ─── Inbox ─── */

model InboxMessage {
  id          String   @id @default(cuid())
  workspaceId String
  platformId  String
  senderName  String
  senderAvatar String?
  message     String
  isRead      Boolean  @default(false)
  isReplied   Boolean  @default(false)
  reply       String?
  platformType String
  externalId  String?
  messageType String   @default("comment") // comment, dm, mention
  assigneeId  String?
  // Status workflow: new → assigned → in_progress → resolved
  status      String   @default("new") // new, assigned, in_progress, resolved
  slaStartedAt   DateTime? // when SLA clock started (on first assign / message receipt)
  firstResponseAt DateTime? // when first reply was sent
  resolvedAt  DateTime? // when resolved
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform  Platform  @relation(fields: [platformId], references: [id])
  assignee  WorkspaceMember? @relation(fields: [assigneeId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, isRead])
  @@index([workspaceId, status])
  @@index([platformId])
  @@index([assigneeId])
}

/* ─── Analytics Snapshots ─── */

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  workspaceId String
  date        String   // YYYY-MM-DD
  platform    String?
  metricType  String   // reach, impressions, engagement, followers, clicks, conversions
  value       Int
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, date, platform, metricType])
  @@index([workspaceId, date])
  @@index([workspaceId, metricType])
}

/* ─── Notifications ─── */

model Notification {
  id          String   @id @default(cuid())
  workspaceId String
  type        String   // publish_success, publish_failed, approval_requested, inbox_new, token_expiring, channel_disconnected
  title       String
  body        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isRead])
  @@index([workspaceId, createdAt])
}

/* ─── Settings ─── */

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("string")
}

/* ─── Draft Persistence (MISS-04) ─── */

// One draft row per user per workspace — upserted on every autosave tick.
model ContentDraft {
  id          String   @id @default(cuid())
  workspaceId String
  authorId    String
  content     Json     // { title, caption, hashtags, note, campaignId, mediaIds, scheduleMode }
  channelIds  String[] // platform UUIDs selected in the compose view
  scheduledAt String?  // ISO string, null when scheduleMode != 'schedule'
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, authorId])
  @@index([workspaceId])
}

/* ─── Transactional Outbox (MISS-01) ─── */

// Written in the same DB transaction as Content + PublishJob.
// Dispatcher in publish-worker polls this table and enqueues to BullMQ.
// Uses FOR UPDATE SKIP LOCKED to prevent double-claiming by concurrent dispatchers.
model OutboxEvent {
  id            String    @id @default(cuid())
  workspaceId   String
  aggregateType String    @default("content")
  aggregateId   String    // contentId
  eventType     String    @default("publish_requested")
  payload       Json      // { jobId, contentId, platformId, workspaceId, scheduledAt, idempotencyKey, publicationId, revisionId }
  traceParent   String?
  // Issue #148: explicit state machine — pending, claimed, delivered, retry_wait, dead_letter, cancelled
  status        String    @default("pending")
  attemptCount  Int       @default(0)
  availableAt   DateTime  @default(now())
  // Issue #148: lease/fencing fields
  lockedAt      DateTime?
  lockedBy      String?   // dispatcher instance ID
  lockExpiresAt DateTime? // when the lease expires (for crash recovery)
  deliveredAt   DateTime?
  // Issue #148: error classification
  lastError     String?
  lastErrorCategory String? // redis, db, serialization, payload, config
  lastSafeError String?     // safe user message (no secrets)
  // Issue #148: dead-letter + replay
  deadLetteredAt DateTime?
  replayedFromId String?    // original event ID if this is a replay
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, availableAt])
  @@index([aggregateId])
  // Issue #148: index for lease expiry recovery queries
  @@index([status, lockExpiresAt])
}

/* ─── Inbox Saved Replies ─── */

model SavedReply {
  id          String   @id @default(cuid())
  workspaceId String
  title       String   // short name shown in picker
  body        String   // Persian body with {نام}, {کانال} variables
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

/* ─── Inbox Auto-Tag Rules ─── */

model AutoTagRule {
  id          String   @id @default(cuid())
  workspaceId String
  keyword     String   // case-insensitive substring match
  tag         String   // label applied to matching messages
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

/* ─── Comment-to-DM Automation (#209) ─── */

model CommentDmRule {
  id              String   @id @default(cuid())
  workspaceId     String
  platformId      String   // Instagram platform ID
  publicationId   String?  // null = workspace-wide; set = scoped to this publication
  igPostId        String?  // Instagram post ID, populated after publish succeeds
  keyword         String   // primary keyword (kept for back-compat + index); keywords[0]
  keywords        Json?    // string[] of trigger keywords (normalized on match)
  excludeKeywords Json?    // string[] of negative keywords that suppress the DM
  dmTemplate      String   // DM body, supports {نام} variable
  buttonText      String?  // optional quick-reply button label
  buttonUrl       String?  // optional quick-reply button URL
  publicReply     String?  // Optional public comment reply
  optOutKeyword   String   @default("نه") // comment keyword to suppress DM
  freqCapHours    Int      @default(24) // min hours between DMs to same user
  status          String   @default("active") // draft, active, paused, needs_attention
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform     Platform     @relation(fields: [platformId], references: [id], onDelete: Cascade)
  publication  Publication? @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([platformId, isActive])
}

model CommentDmLog {
  id           String   @id @default(cuid())
  workspaceId  String
  ruleId       String
  commentId    String   // external comment ID
  senderUserId String   // Instagram user ID of commenter
  sentAt       DateTime @default(now())
  status       String   @default("sent") // sent, skipped, failed

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([ruleId, commentId])
  @@index([workspaceId])
  @@index([ruleId, senderUserId, sentAt])
}

/* ─── #203: Queue-based scheduling (Buffer model) ─── */

model PostingSchedule {
  id           String   @id @default(cuid())
  workspaceId  String
  platformId   String
  // JSON array of { day: 0-6 (Sat=0), slots: ["09:00", "12:30", ...] }
  // Sat-Wed = work days (0-3), Thu=4, Fri=5 (weekend)
  schedule     Json
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform  Platform  @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platformId])
  @@index([workspaceId])
}

/* ─── #204: Best-time-to-post suggestions ─── */

model EngagementHeatmap {
  id           String   @id @default(cuid())
  workspaceId  String
  platform     String   // telegram, instagram, linkedin, etc.
  // weekday: 0-6 (Sat=0), hour: 0-23
  weekday      Int
  hour         Int
  avgEngagement Float  @default(0) // average engagement score (normalized)
  sampleCount  Int      @default(0) // number of posts analyzed
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform, weekday, hour])
  @@index([workspaceId, platform])
}
