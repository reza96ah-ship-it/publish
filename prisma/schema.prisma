  workspaceId  String
  ruleId       String
  commentId    String   // external comment ID
  senderUserId String   // Instagram user ID of commenter
  sentAt       DateTime @default(now())
  status       String   @default("sent") // sent, skipped, failed

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([ruleId, commentId])
  @@index([workspaceId])
  @@index([ruleId, senderUserId, sentAt])
}

/* ─── #203: Queue-based scheduling (Buffer model) ─── */

model PostingSchedule {
  id           String   @id @default(cuid())
